# Exclude everything by default
*

# Include only what we need
!config/
!scanners/
!intel_gathering/
!utils/
!templates/
!main.py
!requirements.txt
!Dockerfile
!docker-compose.yml
!README.md
!.env.example

# Exclude potential sensitive or unnecessary files even if in included dirs
**/*.pyc
**/__pycache__
**/.env
**/venv
**/output/*
!output/.gitkeep
.git/
.gitignore
.dockerignore
